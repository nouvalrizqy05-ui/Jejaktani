# WAJIB diisi, kalau tidak Snap.js Midtrans akan gagal dimuat sama sekali
# (index.html akan berisi literal "%VITE_MIDTRANS_SNAP_URL%" di src script).

# Untuk testing/demo juri -- WAJIB pakai Sandbox:
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js

# Untuk Production, HANYA setelah dapat persetujuan bank (lihat dashboard
# Midtrans kalian), ganti ke:
# VITE_MIDTRANS_SNAP_URL=https://app.midtrans.com/snap/snap.js

# Client Key dari dashboard Midtrans (aman untuk frontend/publik, BEDA
# dengan Server Key yang harus tetap rahasia di backend saja).
VITE_MIDTRANS_CLIENT_KEY=Mid-client-xxxxxxxxx
